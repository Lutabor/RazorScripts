say 'Guards Room'  
wait 100
// Checks for inn
if gumpexists 2393832411
    getlabel backpack pingCheck 
    if name = 'Spellbreaker'   
        gumpresponse 4
        getlabel backpack pingCheck
    elseif name = 'Lutabor'
        gumpresponse 4
        getlabel backpack pingCheck     
    else 
        gumpresponse 5
        waitforgump 2393832411 200
        gumpresponse 100   
        getlabel backpack pingCheck
    endif    
