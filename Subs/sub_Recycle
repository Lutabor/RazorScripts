// all the logic

if varexist _id_wand
    @unsetvar _id_wand
endif

@clearignore
// === Recycle Section
@setvar _loop_recycle 1
while _loop_recycle == 1 and findtype "sewing kit|saw|pen and ink|tongs|tool kit" backpack as breakdowntool
    getlabel backpack pingCheck
    while not varexist _id_wand and findtype 20496 backpack as IDwand
        @getlabel IDwand _label
        if "(15 " in _label or "(14 " in _label or "(13 " in _label or "(12 " in _label or "(11 " in _label or "(10 " in _label or "(9 " in _label or "(8 " in _label or "(9 " in _label or "(6 " in _label or "(5 " in _label or "(4 " in _label or "(3 " in _label or "(2 " in _label
            overhead "ID Wand usage getting low :: {{_label}}" 1769
        endif
        if "(1 uses remaining)" in _label or "(1 use remaining)" in _label
            overhead "ID Wand is spent - recycling it :: {{_label}}" 1779
            while not gumpexists 949095101
                while queued
                    //donothing
                endwhile
                dclick breakdowntool
                waitforgump 949095101 1000
            endwhile
            while not ingump "Recycle Single Item" 949095101
                gumpresponse 2
                waitforgump 949095101 1000
            endwhile
            gumpresponse 3
            waitforgump 949095101 1000
            sysmsg "target {{IDwand}}"
            target IDwand
            getlabel backpack ping
            pause 300
            gumpclose 949095101

            if varexist _id_wand
                @unsetvar _id_wand
            endif
        else
            @setvar _id_wand  IDwand
        endif
    endwhile

    if varexist _id_wand
        if findtype 5056|5059|5060|5061|5063|5070|5074|5075|5076|5078|5085|5089|5090|5101|5103|5105|5106|5129|5131|5132|5135|5138|5139|5142|5143|5144|5146|5201|5203|5204|5205|5207|7169|7170|7173|7175|7177|7179|7181|7610|7947|31003|31004|31005|31006|31007|31008|31009|31010|31011|31012|31015|31191|31017|31019|31021|31023|31025|31027|31029|31031|31033|31035|31037|31038|31041|31043|31045|31047|31049|31051|31053|31055|3834|3740|3742|3762|3763|10245|20006|20008|20010|20012|20014|20016|7026|7027|7029|7031|7033|7034|7035|7107|7109|31002|31130|3920|5042|5117|30990|30993|30994|30995|31184|31186|3719|3938|5121|5123|5125|30989|30992|30996|30997|30998|31176|31188|3568|3713|3721|3932|5040|5044|5112|5127|5177|5179|5181|30991|30999|31000|31001|31014|31178|31180|31182|3909|3911|3913|3915|3917|3934|3937|5046|5049|5115|5119|5182|5185|5187|30988|31128|31190|22187|31141|31142|31169|31172 backpack as IDitem
            @getlabel IDitem desc

            if "blessed" in desc
                @ignore IDitem
            elseif _util_ltrap_recycler__check_all_items == 1  or  "unidentified" in desc
                sysmsg desc 99
                while queued
                    //donothing
                endwhile

                @getlabel _id_wand _label
                if "(1 uses remaining)" in _label or "(1 use remaining)" in _label
                    overhead "ID Wand is spent - should not get here - fix script - {{_label}}" 1779
                    overhead "this is spent" 1779 _id_wand
                    hotkey 'play script: Subs\Routing'
                endif
                dclick _id_wand
                wft 1000
                target IDitem
                waitforsysmsg "You identify the item." 1000
                getlabel IDitem desc
                #if "blessed" in desc
                #    @ignore IDitem
                #else
                    ## _fate_of_item - 0 dunno - 1 keep - 2 recycle
                    @setvar _fate_of_item 0
                    foreach _keep_descr in _util_ltrap_recycler__keep_list
                        if _fate_of_item == 0 and _keep_descr in desc
                            @setvar _fate_of_item 1
                            break
                        endif
                    endfor
                    if _fate_of_item == 0
                        foreach _recycle_descr in _util_ltrap_recycler__recycle_list
                            if _fate_of_item == 0 and _recycle_descr in desc
                                @setvar _fate_of_item 2
                                break
                            endif
                        endfor
                    endif

                    if _fate_of_item == 1
                        ## keep it
                        @ignore IDitem
                        overhead "This one is worth keeping..." 2091
                        overhead "*strong magic*" 2091 IDitem
                        say "[surprise" 2091
                    elseif _fate_of_item == 2
                        ## recycle it
                        overhead "*trash*" 1779 IDitem
                        while not gumpexists 949095101
                            while queued
                                //donothing
                            endwhile
                            dclick breakdowntool
                            waitforgump 949095101 1000
                        endwhile
                        while not ingump "Recycle Single Item" 949095101
                            gumpresponse 2
                            waitforgump 949095101 1000
                        endwhile
                        gumpresponse 3
                        waitforgump 949095101 1000
                        target IDitem
                        getlabel backpack ping
                        pause 300
                        gumpclose 949095101
                    else
                        ## unkown
                        overhead "*unknown*"
                        @ignore IDitem
                    endif
                ## if not blessed
                #endif

            else
                @ignore IDitem
            endif
            #if not findtype 20496 backpack
            #    overhead "no more id wands"
            #    break
            #endif
        else
            sysmsg "no more unids"
            #@setvar _loop_recycle 0
            if gumpexists 949095101
                gumpclose 949095101
            endif
            break
        endif
        if gumpexists 949095101
            gumpclose 949095101
        endif
    ## if find IDwand
    else
        sysmsg "no more id-wands"
        break
        @setvar _loop_recycle 0
    endif
endwhile


