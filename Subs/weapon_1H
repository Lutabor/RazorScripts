// Weapon 1h
// overhead 'Weapon Swap 1h'
while not dead
    // kryss assasin dager, thunter knife, kukri, warfork, eep, rapier, sabre
    while skill 'Fencing' >= 80 and findtype 5121|30996|31188|31176|5125|30989|30997|30998 backpack as _1hWeapon
        getlabel _1hWeapon desc
        if 'exceptional' in desc
            dclick _1hWeapon
            overhead 'Fencing Weapon'
            getlabel backpack pingCheck 
            break
        else 
            @ignore _1hWeapon
        endif 
    endwhile
    // pick hammer, war axe, mace, maul, war mace, skullclub, cudgel, club
    while skill 'Mace Fighting' >= 80 and findtype 5181|5040|3932|5179|5127|3100|31014|5044 backpack as _1hWeapon
        getlabel _1hWeapon desc
        if 'exceptional' in desc
            dclick _1hWeapon
            overhead 'Mace Weapon'
            getlabel backpack pingCheck 
            break
        else 
            @ignore _1hWeapon
        endif
    endwhile
    // cutlass, Katanna, scimitar, broadsword, longsword, viking, norse, 
    while skill 'Swordsmanship' >= 80 and findtype 5185|5119|5046|3934|3937|5049|31128 backpack as _1hWeapon
        getlabel _1hWeapon desc
        if 'exceptional' in desc
            dclick _1hWeapon
            overhead 'Sword Weapon'
            getlabel backpack pingCheck 
            break
        else 
            @ignore _1hWeapon
        endif 
    endwhile                
    // heater kite bronze metal buckler, parry knife, boneshield, wdKite, chaos, wooden
    while findtype 7031|7029|7026|7035|7027|31002|31130|7033|7107|7034 backpack as _Shield
        getlabel _Shield desc
        if 'exceptional' in desc
            if not casting and not targetexists  
                dclick _Shield
                overhead 'Shield'
                getlabel backpack pingCheck 
            endif
               
        else 
            @ignore _Shield
        endif 
    endwhile
