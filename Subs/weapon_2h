// WEAPON 2H
overhead 'Weapon Swap 2h'
while not dead
    while skill 'Arcane' >= 80 and findtype 31017|31019|31021|31023|31025|31029|31031|31033|31035|31037|31038|31041|31043|31045|31047|31049|31051|31053|31055 backpack as _2hWeapon
        getlabel _2hWeapon desc
        if 'exceptional' in desc
            dclick _2hWeapon
            overhead 'Arcane Weapon'
            getlabel backpack pingCheck 
            break
        else 
            @ignore _2hWeapon
        endif 
    endwhile
    // Harpoon, Trident
    while skill 'Fishing' >= 80 and findtype 31169|31172 backpack as _2hWeapon
        getlabel _2hWeapon desc
        if 'exceptional' in desc
            dclick _2hWeapon
            overhead 'Fishing Weapon'
            getlabel backpack pingCheck 
            break
        else 
            @ignore _2hWeapon
        endif 
    endwhile  
    // short spear, pitchfork, long spear, sarissa
    while skill 'Fencing' >= 80 and findtype 5123|3719|3938|30992 backpack as _2hWeapon
        getlabel _2hWeapon desc
        if 'exceptional' in desc
            dclick _2hWeapon
            overhead 'Fencing Weapon'
            getlabel backpack pingCheck 
            break
        else 
            @ignore _2hWeapon
        endif  
    endwhile    
    // war hammer, sledgehammer, great mace, spiked club, quarter, gnarled, black, crook, giant club,
    while skill 'Mace Fighting' >= 80 and findtype 5177|31001|31180|31182|3721|5112|3568|3713|31178 backpack as _2hWeapon
        getlabel _2hWeapon desc
        if 'exceptional' in desc
            dclick _2hWeapon
            overhead 'Mace Weapon'
            getlabel backpack pingCheck 
            break
        else 
            @ignore _2hWeapon
        endif 
    endwhile
    // axe, battle axe, double axe, executioner, lg battle axe, 2h axe, bardiche, halberd, zweilander, giant axe
    while skill 'Swordsmanship' >= 80 and findtype 3913|3911|3915|3909|5115|5187|3917|5182|30988|31190 backpack as _2hWeapon
        getlabel _2hWeapon desc
        if 'exceptional' in desc
            dclick _2hWeapon
            overhead 'Sword Weapon'
            getlabel backpack pingCheck 
            break
        else 
            @ignore _2hWeapon
        endif
    endwhile    
    // caesti, fistblade, martial scroll
    while skill 'Wrestling' >= 80 and findtype 31141|31142|22187 backpack as _2hWeapon
        getlabel _2hWeapon desc
        if 'exceptional' in desc
            dclick _2hWeapon
            overhead 'Wrestling Weapon'
            getlabel backpack pingCheck 
            break
        else 
            @ignore _2hWeapon
        endif
    endwhile
    break 
endwhile
