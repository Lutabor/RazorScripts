//  ---- clears bag by restockand then resupplies

if findtype '62760' ground -1 -1 2 as GlowingBarrel
    overhead 'Resupply v2.00'   
    dclick GlowingBarrel
    getlabel backpack pingCheck
    // ----- Repair Bench
    if findtype '29355|29354|repair bench' ground -1 -1 2 as repairBench
        overhead 'Repair Bench'
        dclick repairBench
        wait 1000
        dclick repairBench
        getlabel backpack pingCheck
        dclick repairBench
        wait 1000
        dclick repairBench
        getlabel backpack pingCheck
    endif    
    // ----- RESOURCE CONVERSION       
    if findtype '7133' self as log
        dclick log
        wait 500
    endif      
    // ----- Ore & Wood
    while findtype 'iron ore|dull copper ore|shadow ore|copper ore|bronze ore|gold ore|agapite ore|verite ore|valorite ore|avarite ore' backpack as ore
        overhead 'Smelting Ore'
        dclick ore
        wait 1000
        if insysmsg 'You have no idea how to smelt'
            break
        endif
    endwhile    
    // ----- Loading Shelf Items
        overhead 'Loading Shelf Items'
        getlabel backpack pingCheck
        menu 0x58405873 0
        wft 500
        target self
        getlabel backpack pingCheck
        menu 0x58405873 0
        wft 500
        target self
        getlabel backpack pingCheck
    // ----- MAGIC ITEM RECYCLE - ornate elven chest, 11762
    overhead 'Loading Magic Item Recycler'
        getlabel backpack pingCheck
        menu 0x445C4ECE 1
        wft 500
        target self
        getlabel backpack pingCheck
    // ----- USE RECYCLER 
        overhead 'Recycling Magic Items'
        dclick 0x445C4ECE
        waitforgump 4045111101
        gumpresponse 7
        waitforgump 4045111101
        gumpresponse 6
        waitforgump 4045111101
        gumpresponse 6
    // ----- STOCKPILE 23034
        overhead 'Loading Stockpile'
        getlabel backpack pingCheck
        menu 0x445B568A 0
        wft 500
        target self
        getlabel backpack pingCheck
    // ----- GRAB FROM RECYCLER
        menu 0x445B568A 0
        wft 500
        target 0x445C4ECE
        getlabel backpack pingCheck
    // ----- MAGICAL ITEM VAULT
    //    if find 0x4237D1E9 ground -0 -0 2
        dclick 0x4237D1E9
        waitforgump 938517546
        gumpresponse 2
        waitfortarget 222
        waitforgump 938517546
        target 'self'  
        getlabel backpack pingCheck 
        // ----- Clear Recycler
        waitforgump 938517546
        gumpresponse 2
        waitfortarget 222
        target 0x445C4ECE        
        getlabel backpack pingCheck  
        // opens magic item vault
        dclick 0x4237D1E9
        wait 888
    //    endif   
  
    // ----- Flooring Resources 1799 0x4BC00655
        overhead 'Flooring Shelf'
        wait 300
        menu 0x4BC00655 0
        wft 500
        target self
        getlabel backpack pingCheck    
 
    // ----- Plant Resources 51189
        overhead 'Garden Shelf'
        wait 300
        menu 0x53FB497E 0
        wft 500
        target self
        getlabel backpack pingCheck
    // ----- bank deposit safe 23034 // Gold Coin 3821
        overhead 'Deposting Gold & Doubloons'
        menu 0x4B597306 0
        getlabel backpack pingCheck    
    // ----- Drops all maps, chains, cloth, dyes etc 
    //      Treasure Chest 0x58D7C2CC || Vined Chest 0x55458644
        menu 0x4DEFB7E8 0
        getlabel backpack pingCheck
        menu 0x4DED4B57 0
        getlabel backpack pingCheck
        menu 0x48CA4142 0
        getlabel backpack pingCheck
        menu 0x48CA68F6 0
        getlabel backpack pingCheck
        menu 0x4901A7BD 0
        getlabel backpack pingCheck
        menu 0x54A2A2C5 0
        getlabel backpack pingCheck
        menu 0x594D737B 0
        getlabel backpack pingCheck
        menu 0x5A670FDB 0
        getlabel backpack pingCheck
        menu 0x54A35158 0
        getlabel backpack pingCheck
        menu 0x4901F124 0
        getlabel backpack pingCheck
        menu 0x5A67189A 0
        getlabel backpack pingCheck
        menu 0x53365B4C 0
        getlabel backpack pingCheck
        
    #// ----- Orbs & Papers & Redlightning
    #while findtype 22336|24434|25359 self as Specialty
    #    lifttype Specialty
    #    wait 1000
    #    drop 0x745EB062
    #endwhile
        
    // ----- restock from shelf and opens shelf
        overhead 'Resupply'
        menu 0x58405873 1
        getlabel backpack pingCheck
        wait 888
        dclick 0x58405873
        wait 1000
    // ----- Open Footlocker
    if find 0x745EB062 ground -1 -1 2 
        dclick 0x745EB062
        wait 888
    endif
    // --- Open Rune Tome
    if findtype 'runetome'self as mybook
        getlabel mybook desc
        if 'Adventure' in desc
            dclick mybook
            wait 888
        endif  
    endif
