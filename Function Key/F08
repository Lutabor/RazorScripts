

clearsysmsg 
// ==== ROGUE & MELEE
while warmode on
    hotkey 'target closest grey monster' 
    getlabel backpack pingCheck
    if not insysmsg 'No one matching that was found on your screen.'  
        overhead '† Target †' 88 lasttarget 
        getlabel backpack pingCheck   
        hotkey 'attack last target' 
        wait 200
    endif
   break 
endwhile

// === DISCO
if skill 'discordance' >= 80
    skill 'discordance'
    getlabel backpack pingCheck
    wft 111
    target self  
    getlabel backpack pingCheck
endif

// ==== TRAPPER 'metal trap'
if skill 'tinkering' >= 80 and skill 'Detecting Hidden' >= 80 
    say [DetonateTrap
    getlabel backpack pingCheck
    if insysmsg 'You detonate a ground trap.'
        if name = 'a stranger' 
            if skill 'detecting hidden' >= 80      
                overhead '80 detonate stranger'
                cooldown 'Detonate' 35000  
            elseif skill 'detecting hidden' >= 84      
                overhead '84 detonate stranger'
                cooldown 'Detonate' 34000  
            elseif skill 'detecting hidden' >= 88      
                overhead '88 detonate stranger'
                cooldown 'Detonate' 33000                  
            elseif skill 'detectng hidden' >= 92      
                overhead '92 detonate stranger'
                cooldown 'Detonate' 32000   
            elseif skill 'detecting hidden' >= 96      
                overhead '96 detonate stranger'
                cooldown 'Detonate' 31000     
            elseif skill 'detecting hidden' >= 100      
                overhead '100 detonate stranger'
                cooldown 'Detonate' 30000     
            endif
        else 
            cooldown 'Detonate' 16100
        endif
    endif  
    getlabel backpack pingCheck
endif

// ==== Steal from nearest
if diffhits < 30 and skill 'stealing' >= 80 and skill 'Hiding' >= 80 and not cooldown 'Hiding' and not cooldown 'Stealth' and not cooldown 'Stealing'
    while not dead
        hotkey 'target closest grey monster' 
        getlabel backpack pingCheck  
        if not insysmsg 'No one matching that was found on your screen.'
            if not hidden 
                clearsysmsg 
                skill "Stealing"
                wft 222
                getlabel backpack pingCheck  
                hotkey 'last target' 
                cooldown "Stealing" 5000 
                break
            endif        

            if hidden 
                clearsysmsg 
                skill "Stealing"
                wft 222
                getlabel backpack pingCheck  
                hotkey 'last target' 
                getlabel backpack pingCheck
                cooldown "Stealing" 5000   
                if not hidden
                    if skill "Stealth" >= 80 and not cooldown "Smoke bomb" and not cooldown "Hiding" and not cooldown "Stealth" and findtype 52149 backpack as sbombs
                        while queued
                            //donothing
                        endwhile
                        say [SmokeBomb
                        getlabel backpack pingCheck
                        if hidden
                            if not cooldown "Smoke bomb"
                                cooldown "Smoke bomb" 60000
                                break
                            endif
                        endif
                    endif
                    if not hidden and skill "Magery" >= 80 and mana >= 20
                        hotkey 'Cancel Current Target'
                        cast "Invisibility"
                        wft 3000
                        target self
                        warmode on
                        warmode off
                        hotkey 'Cancel Current Target'
                        break
                    endif
                endif
            endif   
        endif
        break
    endwhile
endif

